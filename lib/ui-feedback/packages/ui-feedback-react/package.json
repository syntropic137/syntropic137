{
  "name": "@syn137/ui-feedback-react",
  "version": "0.1.0",
  "description": "React feedback widget for capturing contextual UI feedback",
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./index.d.ts"
    }
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc -b && vite build",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "html2canvas": "^1.4.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.4.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "~5.7.2",
    "vite": "^6.2.0",
    "vite-plugin-dts": "^4.5.0"
  },
  "keywords": [
    "react",
    "feedback",
    "widget",
    "screenshot",
    "voice-notes",
    "ui-feedback"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/syntropic137/syntropic137.git",
