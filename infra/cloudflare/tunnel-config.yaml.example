# Cloudflare Tunnel Configuration for Syn137 Self-Host
#
# Usage: cloudflared runs as a container in the Docker Compose stack (see docker-compose.selfhost.yaml).
# It connects inside the Docker network, so `gateway:8081` resolves to the nginx auth-guarded port.
# This file is an alternative for running cloudflared standalone (outside Docker), in which case
# `gateway` must resolve from your host — e.g. `localhost` or the Docker host IP — but port 8081
# must still be exposed and targeted. Do NOT change to port 80 or 8137 (unauthenticated).
#
# SECURITY: Both ingress rules target the nginx server block that enforces basic auth via
# SYN_API_PASSWORD. SYN_API_PASSWORD MUST be set in your .env before activating the tunnel.
#
# Setup:
#   1. Create tunnel: cloudflared tunnel create syn-selfhost
#   2. Copy credentials: cp ~/.cloudflared/<tunnel-id>.json ./credentials.json
#   3. Configure DNS: cloudflared tunnel route dns syn-selfhost syn.yourdomain.com
#   4. Copy this file: cp tunnel-config.yaml.example tunnel-config.yaml
#   5. Edit with your tunnel ID and domain
#   6. Run: cloudflared tunnel --config tunnel-config.yaml run

# Your tunnel ID (from: cloudflared tunnel list)
tunnel: <TUNNEL-ID>

# Path to credentials file
credentials-file: /etc/cloudflared/credentials.json

# Ingress rules define how traffic is routed
ingress:
  # Syn137 Dashboard UI + API (auth-guarded nginx block — requires SYN_API_PASSWORD)
  - hostname: syn.yourdomain.com
    service: http://gateway:8081
    originRequest:
      # Skip TLS verification for internal Docker service communication
      noTLSVerify: true
      # Connection timeout
      connectTimeout: 30s
      # Keep-alive timeout
      tcpKeepAlive: 30s

  # Syn137 API direct access (auth-guarded nginx block — requires SYN_API_PASSWORD)
  - hostname: api.syn.yourdomain.com
    service: http://gateway:8081
    originRequest:
      noTLSVerify: true
      connectTimeout: 30s
      # Longer timeout for API requests
      httpHostHeader: api.syn.yourdomain.com

  # Catch-all rule (required - must be last)
  - service: http_status:404

# Optional: Metrics and logging
# metrics: localhost:2000
# loglevel: info
