# ============================================================================
# AEF INFRASTRUCTURE DEPLOYMENT - ENVIRONMENT CONFIGURATION
# ============================================================================
#
# Copy this file to .env and fill in your values.
# Required variables are marked with [REQUIRED].
#
# For local development, most defaults work out of the box.
# For self-host/production, configure the Cloudflare and secrets sections.
# ============================================================================

# ============================================================================
# DEPLOYMENT ENVIRONMENT
# ============================================================================

# Deployment target: local, selfhost, staging, production
# Affects logging verbosity, restart policies, and feature flags.
DEPLOY_ENV=local

# Docker Compose project name (prefixes all container names)
# Example: syn → containers named syn-dashboard, syn-postgres, etc.
COMPOSE_PROJECT_NAME=syntropic137

# Container registry for pre-built images (optional)
# Leave empty to build locally. Set for CI/CD deployments.
# Example: ghcr.io/syntropic137
CONTAINER_REGISTRY=

# Image tag for deployment
# Use 'latest' for dev, specific versions (v1.2.3) for production.
IMAGE_TAG=latest

# ============================================================================
# DATABASE (PostgreSQL)
# ============================================================================

# PostgreSQL password
# LOCAL DEV ONLY - This default value is for development convenience.
# For PRODUCTION, you MUST use Docker secrets instead (file: secrets/db-password.txt).
# Generate a secure password with: openssl rand -hex 32
POSTGRES_PASSWORD=syn_dev_password

# Database name
POSTGRES_DB=syn

# Database user
POSTGRES_USER=syn

# ============================================================================
# CLOUDFLARE TUNNEL (Self-Host Only)
# ============================================================================
# Required for external access to self-host deployment.
# Skip this section for local development.

# Cloudflare account ID [REQUIRED for self-host]
# Find at: Cloudflare Dashboard → Account Home → right sidebar
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare API token [REQUIRED for tunnel setup script]
# Permissions needed: Zone:Read, DNS:Edit, Cloudflare Tunnel:Edit
# Create at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# Cloudflare Zone ID for your domain [REQUIRED for self-host]
# Find at: Domain overview page → right sidebar → API section
CLOUDFLARE_ZONE_ID=

# Domain for AEF access [REQUIRED for self-host]
# Example: syn.yourdomain.com
# API will be available at: api.syn.yourdomain.com
SYN_DOMAIN=

# Tunnel name (created automatically if doesn't exist)
CLOUDFLARE_TUNNEL_NAME=syn-selfhost

# Tunnel token [REQUIRED for self-host]
# Save to: infra/docker/secrets/cloudflare-tunnel-token.txt
# Get from Cloudflare Zero Trust Dashboard after creating tunnel:
# Access → Tunnels → Create → Copy token
# Or via CLI: cloudflared tunnel token <tunnel-name>
#
# NOTE: The token is now loaded from a Docker secret file, NOT this env var.
# Copy your token to: infra/docker/secrets/cloudflare-tunnel-token.txt
CLOUDFLARE_TUNNEL_TOKEN=

# ============================================================================
# GITHUB APP (Authentication)
# ============================================================================
# Required for GitHub integration. See: docs/deployment/github-app-setup.md
#
# Security: Tier 1 (single-tenant) — no API auth, Docker network isolation.
# Run `just setup --stage security_audit` to validate your security posture.

# GitHub App ID (numeric) [REQUIRED]
# Find at: https://github.com/settings/apps/<app-name> → General → App ID
SYN_GITHUB_APP_ID=

# GitHub App slug/name [REQUIRED]
# Example: 'syn-engineer-beta' → commits appear as 'syn-engineer-beta[bot]'
SYN_GITHUB_APP_NAME=

# RSA private key is stored as a Docker secret, not an env var.
# Copy your private key to: infra/docker/secrets/github-private-key.pem

# Webhook secret is stored as a Docker secret.
# Generate and copy to: infra/docker/secrets/github-webhook-secret.txt
# Generate with: openssl rand -hex 32

# ============================================================================
# SECRETS MANAGEMENT (1Password) — Optional
# ============================================================================
# Enable 1Password secret resolution for the dashboard container.
# When set, the dashboard auto-fetches secrets from the 'syntropic137-config'
# item in the selected vault at startup. You can OMIT most secret values from
# this file — the resolver fills them in. Precedence: shell > 1Password > .env.
#
# Full setup: docs/development/1password-secrets.md
# ADR: docs/adrs/ADR-045-secrets-management-standard.md

# Vault to resolve from (e.g., syn137-dev, syn137-prod)
OP_VAULT=

# Service account token — vault-specific to avoid collisions.
# On macOS, store in Keychain (auto-retrieved by selfhost recipes):
#   security add-generic-password -U -a "$USER" \
#     -s "SYN_OP_SERVICE_ACCOUNT_TOKEN_SYN137_DEV" -w "ops_..."
# On Linux/CI, set the vault-specific env var:
#   export OP_SERVICE_ACCOUNT_TOKEN_SYN137_DEV=ops_...
# Or set the generic fallback here (used if vault-specific is not found):
OP_SERVICE_ACCOUNT_TOKEN=

# Include 1Password CLI in dashboard image (set to 1 to enable)
INCLUDE_OP_CLI=0

# ============================================================================
# MINIO (Object Storage)
# ============================================================================
# Used for artifact and conversation storage.

# MinIO root credentials (change for production!)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ============================================================================
# REDIS
# ============================================================================
# Redis password for selfhost deployments.
# Also stored as Docker secret: infra/docker/secrets/redis-password.txt
# Generate with: openssl rand -hex 32
REDIS_PASSWORD=changeme

# ============================================================================
# RESOURCE LIMITS
# ============================================================================
# Adjust based on your hardware. Defaults are conservative for self-host.

# Dashboard API limits
DASHBOARD_MEMORY_LIMIT=512m
DASHBOARD_CPU_LIMIT=0.5

# UI (nginx) limits
UI_MEMORY_LIMIT=256m
UI_CPU_LIMIT=0.25

# PostgreSQL limits
POSTGRES_MEMORY_LIMIT=1g
POSTGRES_CPU_LIMIT=1.0

# Event Store limits
EVENT_STORE_MEMORY_LIMIT=512m

# Collector limits
COLLECTOR_MEMORY_LIMIT=256m
COLLECTOR_CPU_LIMIT=0.25

# MinIO limits
MINIO_MEMORY_LIMIT=256m
MINIO_CPU_LIMIT=0.25

# Redis limits
REDIS_MEMORY_LIMIT=256m
REDIS_CPU_LIMIT=0.25

# ============================================================================
# LOGGING
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
# Use DEBUG for troubleshooting, INFO for production.
LOG_LEVEL=INFO

# Log format: json (production), console (development)
LOG_FORMAT=json

# ============================================================================
# SELF-HOST-SPECIFIC (Optional)
# ============================================================================
# Additional tuning for self-host deployment.

# Enable automatic container restarts
RESTART_POLICY=always

# PostgreSQL tuning (adjust based on available RAM)
# shared_buffers: 25% of RAM recommended
PG_SHARED_BUFFERS=256MB
PG_WORK_MEM=16MB

# Event Store batching
ES_BATCH_SIZE=100

# Backup settings
BACKUP_SCHEDULE="0 3 * * *"
BACKUP_RETENTION_DAYS=7
BACKUP_DIR=/var/backups/syn
