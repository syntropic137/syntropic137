# ============================================================================
# AEF INFRASTRUCTURE DEPLOYMENT - ENVIRONMENT CONFIGURATION
# ============================================================================
#
# Copy this file to .env and fill in your values.
# Required variables are marked with [REQUIRED].
#
# For local development, most defaults work out of the box.
# For homelab/production, configure the Cloudflare and secrets sections.
# ============================================================================

# ============================================================================
# DEPLOYMENT ENVIRONMENT
# ============================================================================

# Deployment target: local, homelab, staging, production
# Affects logging verbosity, restart policies, and feature flags.
DEPLOY_ENV=local

# Docker Compose project name (prefixes all container names)
# Example: aef → containers named aef-dashboard, aef-postgres, etc.
COMPOSE_PROJECT_NAME=aef

# Container registry for pre-built images (optional)
# Leave empty to build locally. Set for CI/CD deployments.
# Example: ghcr.io/agentparadise
CONTAINER_REGISTRY=

# Image tag for deployment
# Use 'latest' for dev, specific versions (v1.2.3) for production.
IMAGE_TAG=latest

# ============================================================================
# DATABASE (PostgreSQL)
# ============================================================================

# PostgreSQL password
# LOCAL DEV ONLY - This default value is for development convenience.
# For PRODUCTION, you MUST use Docker secrets instead (file: secrets/db-password.txt).
# Generate a secure password with: openssl rand -hex 32
POSTGRES_PASSWORD=aef_dev_password

# Database name
POSTGRES_DB=aef

# Database user
POSTGRES_USER=aef

# ============================================================================
# CLOUDFLARE TUNNEL (Homelab Only)
# ============================================================================
# Required for external access to homelab deployment.
# Skip this section for local development.

# Cloudflare account ID [REQUIRED for homelab]
# Find at: Cloudflare Dashboard → Account Home → right sidebar
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare API token [REQUIRED for tunnel setup script]
# Permissions needed: Zone:Read, DNS:Edit, Cloudflare Tunnel:Edit
# Create at: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# Cloudflare Zone ID for your domain [REQUIRED for homelab]
# Find at: Domain overview page → right sidebar → API section
CLOUDFLARE_ZONE_ID=

# Domain for AEF access [REQUIRED for homelab]
# Example: aef.yourdomain.com
# API will be available at: api.aef.yourdomain.com
AEF_DOMAIN=

# Tunnel name (created automatically if doesn't exist)
CLOUDFLARE_TUNNEL_NAME=aef-homelab

# Tunnel token [REQUIRED for homelab]
# Get from Cloudflare Zero Trust Dashboard after creating tunnel:
# Access → Tunnels → Create → Copy token
# Or via CLI: cloudflared tunnel token <tunnel-name>
CLOUDFLARE_TUNNEL_TOKEN=

# ============================================================================
# GITHUB APP (Authentication)
# ============================================================================
# Required for GitHub integration. See: docs/deployment/github-app-setup.md

# GitHub App ID (numeric) [REQUIRED]
# Find at: https://github.com/settings/apps/<app-name> → General → App ID
AEF_GITHUB_APP_ID=

# GitHub App slug/name [REQUIRED]
# Example: 'aef-engineer-beta' → commits appear as 'aef-engineer-beta[bot]'
AEF_GITHUB_APP_NAME=

# Installation ID [REQUIRED]
# Find at: https://github.com/settings/installations → Configure → URL contains ID
AEF_GITHUB_INSTALLATION_ID=

# RSA private key is stored as a Docker secret, not an env var.
# Copy your private key to: infra/docker/secrets/github-private-key.pem

# Webhook secret is stored as a Docker secret.
# Generate and copy to: infra/docker/secrets/github-webhook-secret.txt
# Generate with: openssl rand -hex 32

# ============================================================================
# RESOURCE LIMITS
# ============================================================================
# Adjust based on your hardware. Defaults are conservative for homelab.

# Dashboard API limits
DASHBOARD_MEMORY_LIMIT=512m
DASHBOARD_CPU_LIMIT=0.5

# UI (nginx) limits
UI_MEMORY_LIMIT=256m
UI_CPU_LIMIT=0.25

# PostgreSQL limits
POSTGRES_MEMORY_LIMIT=1g

# Event Store limits
EVENT_STORE_MEMORY_LIMIT=512m

# Collector limits
COLLECTOR_MEMORY_LIMIT=256m
COLLECTOR_CPU_LIMIT=0.25

# ============================================================================
# LOGGING
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
# Use DEBUG for troubleshooting, INFO for production.
LOG_LEVEL=INFO

# Log format: json (production), console (development)
LOG_FORMAT=json

# ============================================================================
# HOMELAB-SPECIFIC (Optional)
# ============================================================================
# Additional tuning for homelab deployment.

# Enable automatic container restarts
RESTART_POLICY=always

# PostgreSQL tuning (adjust based on available RAM)
# shared_buffers: 25% of RAM recommended
PG_SHARED_BUFFERS=256MB
PG_WORK_MEM=16MB

# Event Store batching
ES_BATCH_SIZE=100

# Backup settings
BACKUP_SCHEDULE="0 3 * * *"
BACKUP_RETENTION_DAYS=7
BACKUP_DIR=/var/backups/aef
