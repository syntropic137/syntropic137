# ============================================================================
# SYN137 INFRASTRUCTURE / DEPLOYMENT CONFIGURATION
# ============================================================================
#
# This file is AUTO-GENERATED from InfraSettings.
# Do not edit manually - run: just gen-env
#
# Infrastructure config ONLY.
# Application config (API keys, GitHub creds, logging) lives in root .env.
# See root .env.example (auto-generated from Settings classes).
#
# Copy this file to infra/.env and fill in your values.
# ============================================================================

# ============================================================================
# DEPLOYMENT
# ============================================================================

# Container registry for pre-built images (optional). Leave empty to build
# locally. Set for CI/CD deployments. Example: ghcr.io/syntropic137
CONTAINER_REGISTRY=

# Image tag for deployment. Use 'latest' for dev, specific versions (v1.2.3)
# for production.
IMAGE_TAG=latest

# ============================================================================
# DATABASE (PostgreSQL)
# ============================================================================

# PostgreSQL password. LOCAL DEV ONLY - This default value is for development
# convenience. For PRODUCTION, you MUST use Docker secrets instead (file:
# secrets/db-password.txt). Generate a secure password with: openssl rand -hex
# 32
POSTGRES_PASSWORD=syn_dev_password

# Database name.
POSTGRES_DB=syn

# Database user.
POSTGRES_USER=syn

# ============================================================================
# CLOUDFLARE TUNNEL (Self-Host Only)
# ============================================================================

# Cloudflare account ID. [REQUIRED for self-host] Find at: Cloudflare
# Dashboard -> Account Home -> right sidebar.
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare API token. [REQUIRED for tunnel setup script] Permissions needed:
# Zone:Read, DNS:Edit, Cloudflare Tunnel:Edit. Create at:
# https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# Cloudflare Zone ID for your domain. [REQUIRED for self-host] Find at: Domain
# overview page -> right sidebar -> API section.
CLOUDFLARE_ZONE_ID=

# Domain for Syn137 access. [REQUIRED for self-host] Example:
# syn.yourdomain.com. API will be available at: api.syn.yourdomain.com
SYN_DOMAIN=

# Tunnel name (created automatically if doesn't exist).
CLOUDFLARE_TUNNEL_NAME=syn-selfhost

# Tunnel token. [REQUIRED for self-host] With 1Password: auto-resolved from
# vault - leave empty. Without 1Password: paste token here. Get from
# Cloudflare Zero Trust Dashboard after creating tunnel: Networks -> Tunnels
# -> Create -> Copy token. Or via CLI: cloudflared tunnel token <tunnel-name>
CLOUDFLARE_TUNNEL_TOKEN=

# ============================================================================
# 1PASSWORD - Docker Build Arg
# ============================================================================

# Include 1Password CLI in dashboard image (set to 1 to enable). Note:
# OP_SERVICE_ACCOUNT_TOKEN and other 1Password config live in root .env.
INCLUDE_OP_CLI=0

# ============================================================================
# MINIO (Object Storage)
# ============================================================================

# MinIO root credentials (change for production!).
MINIO_ROOT_USER=minioadmin

# MinIO root password (change for production!).
MINIO_ROOT_PASSWORD=minioadmin

# ============================================================================
# REDIS
# ============================================================================

# Redis password for selfhost deployments. Also stored as Docker secret:
# infra/docker/secrets/redis-password.txt. Generate with: openssl rand -hex 32
REDIS_PASSWORD=changeme

# ============================================================================
# RESOURCE LIMITS
# ============================================================================

# API memory limit.
API_MEMORY_LIMIT=512m

# API CPU limit.
API_CPU_LIMIT=0.5

# UI (nginx) memory limit.
UI_MEMORY_LIMIT=256m

# UI (nginx) CPU limit.
UI_CPU_LIMIT=0.25

# PostgreSQL memory limit.
POSTGRES_MEMORY_LIMIT=1g

# PostgreSQL CPU limit.
POSTGRES_CPU_LIMIT=1.0

# Event Store memory limit.
EVENT_STORE_MEMORY_LIMIT=512m

# Collector memory limit.
COLLECTOR_MEMORY_LIMIT=256m

# Collector CPU limit.
COLLECTOR_CPU_LIMIT=0.25

# MinIO memory limit.
MINIO_MEMORY_LIMIT=256m

# MinIO CPU limit.
MINIO_CPU_LIMIT=0.25

# Redis memory limit.
REDIS_MEMORY_LIMIT=256m

# Redis CPU limit.
REDIS_CPU_LIMIT=0.25

# ============================================================================
# SELF-HOST-SPECIFIC (Optional)
# ============================================================================

# Gateway port (nginx reverse proxy). Default 8008 - change to avoid
# conflicts.
SYN_GATEWAY_PORT=8008

# Basic auth for UI and API (recommended when using Cloudflare Tunnel).
# Webhooks are exempt (use HMAC signature verification). Omit or leave empty
# to disable auth (local-only access). Generate a password with: openssl rand
# -hex 16
SYN_API_PASSWORD=

# Basic auth username for UI and API.
SYN_API_USER=admin

# Enable automatic container restarts.
RESTART_POLICY=always

# PostgreSQL tuning: shared_buffers (25% of RAM recommended).
PG_SHARED_BUFFERS=256MB

# PostgreSQL tuning: work_mem.
PG_WORK_MEM=16MB

# Event Store batching size.
ES_BATCH_SIZE=100

# Backup cron schedule.
BACKUP_SCHEDULE="0 3 * * *"

# Number of days to retain backups.
BACKUP_RETENTION_DAYS=7

# Directory for database backups.
BACKUP_DIR=/var/backups/syn
