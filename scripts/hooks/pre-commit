#!/usr/bin/env bash
# pre-commit: invalidate the topology cache stamp when source files change.
#
# fitness-check regenerates topology on demand (commit-SHA cache). This hook
# removes the stamp so the next fitness-check run knows to regenerate.
#
# Install: just install-hooks
set -euo pipefail

CHANGED_SRC=$(git diff --cached --name-only | grep -E '\.(py|rs)$' || true)
if [ -n "$CHANGED_SRC" ]; then
    rm -f .topology/.commit-sha
fi
