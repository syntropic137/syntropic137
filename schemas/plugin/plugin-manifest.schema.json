{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://syntropic137.dev/schemas/plugin/v0.18.0/plugin-manifest.schema.json",
  "description": "Plugin manifest parsed from ``syntropic137-plugin.json``.\n\n``extra=\"ignore\"`` ensures forward compatibility \u2014 unknown fields\nadded in future manifest versions are silently skipped.",
  "properties": {
    "manifest_version": {
      "default": 1,
      "title": "Manifest Version",
      "type": "integer"
    },
    "name": {
      "minLength": 1,
      "title": "Name",
      "type": "string"
    },
    "version": {
      "default": "0.1.0",
      "title": "Version",
      "type": "string"
    },
    "description": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Description"
    },
    "author": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Author"
    },
    "license": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "License"
    },
    "repository": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Repository"
    }
  },
  "required": [
    "name"
  ],
  "title": "PluginManifest",
  "type": "object"
}
