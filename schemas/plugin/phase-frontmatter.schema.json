{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://syntropic137.dev/schemas/plugin/v0.18.0/phase-frontmatter.schema.json",
  "additionalProperties": false,
  "description": "Schema for the YAML frontmatter in phase .md prompt files.\n\nThis models only the optional metadata fields that appear in phase markdown\nfrontmatter \u2014 NOT the full phase definition (which includes required fields\nlike id/name/order that come from workflow.yaml, not frontmatter).\n\nSource of truth for schemas/plugin/phase-frontmatter.schema.json.\nSee ADR-053 for the schema generation strategy.",
  "properties": {
    "model": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Model to use for this phase (e.g., 'sonnet', 'opus').",
      "title": "Model"
    },
    "allowed-tools": {
      "description": "Tools available during this phase (e.g., 'bash', 'git', 'read').",
      "items": {
        "type": "string"
      },
      "title": "Allowed-Tools",
      "type": "array"
    },
    "max-tokens": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Maximum tokens for this phase.",
      "title": "Max-Tokens"
    },
    "timeout-seconds": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Phase timeout in seconds.",
      "title": "Timeout-Seconds"
    },
    "execution-type": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Phase execution type ('sequential' or 'parallel').",
      "title": "Execution-Type"
    },
    "description": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "What this phase does.",
      "title": "Description"
    },
    "argument-hint": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Hint for Claude Code command argument.",
      "title": "Argument-Hint"
    }
  },
  "title": "PhaseFrontmatterSchema",
  "type": "object"
}
