# ============================================================================
# SYNTROPIC137 - ENVIRONMENT CONFIGURATION
# ============================================================================
#
# This file is AUTO-GENERATED from the Settings classes.
# Do not edit manually - run: just gen-env
#
# Copy this file to .env and fill in your values.
# Required variables are marked with [REQUIRED].
# ============================================================================

# ============================================================================
# SECURITY WARNING
# ============================================================================
#
# The Syn137 dashboard and API have no built-in authentication. Access control
# relies entirely on network isolation (Docker internal network). If you expose
# the dashboard via Cloudflare Tunnel or any public URL, you MUST add
# authentication at the reverse proxy layer (e.g., Cloudflare Access, nginx
# basic auth, or VPN). Never expose the dashboard to untrusted networks without
# external authentication in place.
#

# ============================================================================
# SECRETS MANAGEMENT (1PASSWORD)
# ============================================================================
# The vault name is derived automatically from APP_ENVIRONMENT:
#   development → syn137-dev
#   beta        → syn137-beta
#   staging     → syn137-staging
#   production  → syn137-prod
#
# No separate OP_VAULT variable is needed — set APP_ENVIRONMENT and the
# resolver figures out which vault to use. If APP_ENVIRONMENT is 'test',
# 'offline', or unset, 1Password resolution is skipped entirely.
#
# The resolver fetches every field from the 'syntropic137-config' item
# in the derived vault and injects them into the environment.
# Existing env vars are never overwritten.
#
# Precedence (highest → lowest): shell → 1Password → this file.
#
# Full setup guide: docs/development/1password-secrets.md

# Per-vault service account tokens (one per vault, scoped to that vault only).
# The resolver injects the matching token as OP_SERVICE_ACCOUNT_TOKEN before
# calling the op CLI. Shell env always wins: if OP_SERVICE_ACCOUNT_TOKEN is
# already set in your shell it takes priority.
# Leave all blank to set OP_SERVICE_ACCOUNT_TOKEN directly in your shell.

OP_SERVICE_ACCOUNT_TOKEN_SYN137_DEV=
OP_SERVICE_ACCOUNT_TOKEN_SYN137_BETA=
OP_SERVICE_ACCOUNT_TOKEN_SYN137_STAGING=
OP_SERVICE_ACCOUNT_TOKEN_SYN137_PROD=

# ============================================================================
# APPLICATION
# ============================================================================

# Application name for logging and identification
APP_NAME=syntropic137

# Current environment: development, staging, production, test, offline.
# Affects logging verbosity, error handling, and feature flags. Use 'offline'
# for local dev without Docker or external services.
APP_ENVIRONMENT=development

# ============================================================================
# DATABASE
# ============================================================================

# Database connection pool size. Increase for high-traffic production.
DATABASE_POOL_SIZE=5

# Max overflow connections beyond pool_size for burst traffic.
DATABASE_POOL_OVERFLOW=10

# ============================================================================
# EVENT STORE
# ============================================================================

# Event Store Server gRPC host. For Docker: event-store (service name). For
# local dev: localhost
EVENT_STORE_HOST=localhost

# Event Store Server gRPC port.
EVENT_STORE_PORT=50051

# Tenant ID for multi-tenant Event Store Server. Each tenant has isolated
# event streams.
EVENT_STORE_TENANT_ID=syn

# Timeout for Event Store gRPC calls in seconds.
EVENT_STORE_TIMEOUT_SECONDS=30

# DEPRECATED: Use event_store_host and event_store_port instead. Legacy gRPC
# URL for the event store service.
EVENT_STORE_URL=

# ============================================================================
# LOGGING
# ============================================================================

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL. Use DEBUG for
# development, INFO for production.
LOG_LEVEL=INFO

# Log output format: 'json' for structured logs (production), 'console' for
# human-readable (development).
LOG_FORMAT=json

# ============================================================================
# AGENT CONFIGURATION
# ============================================================================

# Anthropic API key. Used when CLAUDE_CODE_OAUTH_TOKEN is not set. Get from:
# https://console.anthropic.com/settings/keys. At least one of
# ANTHROPIC_API_KEY or CLAUDE_CODE_OAUTH_TOKEN is required for agent
# execution.
ANTHROPIC_API_KEY=

# Default timeout for agent operations in seconds.
DEFAULT_AGENT_TIMEOUT_SECONDS=300

# Default max tokens for agent responses.
DEFAULT_MAX_TOKENS=4096

# ============================================================================
# STORAGE
# ============================================================================

# Artifact storage backend: 'database' (PostgreSQL), 's3' (S3-compatible). Start
# with database, migrate to s3 for large artifacts.
ARTIFACT_STORAGE_TYPE=database

# S3 bucket name for artifact storage. Required when artifact_storage_type is
# 's3'.
S3_BUCKET_NAME=

# S3-compatible endpoint URL. Leave empty for AWS S3.
S3_ENDPOINT_URL=

# S3 access key ID. Required when using S3 storage.
S3_ACCESS_KEY_ID=

# S3 secret access key. Required when using S3 storage.
S3_SECRET_ACCESS_KEY=

# ============================================================================
# OTHER
# ============================================================================

# Enable debug mode. Shows detailed errors and enables debug logging. Never
# enable in production.
DEBUG=false

# Event Sourcing Platform database URL for domain events. Format:
# postgresql://user:password@host:port/database Used by Event Store (Rust) for
# event sourcing tables: events, aggregates, etc. For local dev:
# postgresql://syn:syn_dev_password@localhost:5432/syn For Docker:
# postgresql://syn:syn_dev_password@timescaledb:5432/syn
ESP_EVENT_STORE_DB_URL=

# Syn137 Observability database URL for agent metrics and application data.
# Format: postgresql://user:password@host:port/database Used by Dashboard API
# (Python) for: agent_events, workflows, artifacts, projections. For local
# dev: postgresql://syn:syn_dev_password@localhost:5432/syn For Docker:
# postgresql://syn:syn_dev_password@timescaledb:5432/syn NOTE: Points to SAME
# database as ESP after ADR-030 consolidation.
SYN_OBSERVABILITY_DB_URL=

# Container path for workspace directories when running dashboard in Docker.
# Example: /workspaces (mounted volume inside dashboard container)
SYN_WORKSPACE_CONTAINER_DIR=

# Host path for Docker daemon volume mounts. Required when dashboard runs in
# Docker. Example: /Users/user/repo/workspaces
SYN_WORKSPACE_HOST_DIR=

# Claude Code OAuth token. Takes priority over ANTHROPIC_API_KEY when both are
# set. Obtain via: claude setup (Claude Code OAuth flow). At least one of
# CLAUDE_CODE_OAUTH_TOKEN or ANTHROPIC_API_KEY is required for agent
# execution.
CLAUDE_CODE_OAUTH_TOKEN=

# URL for the Collector service (Pattern 2: Event Log + CQRS). Format:
# http://host:port For local dev: http://localhost:8080 For Docker:
# http://collector:8080 When not set, tool events are not sent to collector.
COLLECTOR_URL=

# API key for Collector service authentication (optional).
COLLECTOR_API_KEY=

# URL for hook backend service for observability events. Format:
# http://host:port For local dev: http://localhost:8080 When not set, uses
# JSONL file backend at .agentic/hooks/events.jsonl
HOOK_BACKEND_URL=

# Number of events to batch before sending to hook backend.
HOOK_BATCH_SIZE=50

# Max seconds to wait before flushing buffered hook events.
HOOK_FLUSH_INTERVAL_SECONDS=1.0

# Redis connection URL for caching and control signal queues. Format:
# redis://[:password]@host:port/db For Docker: redis://redis:6379/0 For
# selfhost: built from secrets in selfhost-entrypoint.sh
REDIS_URL=redis://localhost:6379/0

# Port for the dashboard API server.
DASHBOARD_PORT=8000

# Host to bind the dashboard API server.
DASHBOARD_HOST=127.0.0.1

# ============================================================================
# GITHUB APP (Secure Authentication)
# ============================================================================
# GitHub App for secure API access. See docs/deployment/github-app-setup.md

# GitHub App ID. Get from: https://github.com/settings/apps/<app>/general
SYN_GITHUB_APP_ID=

# GitHub App name (slug). Used in commit attribution. Commits will show as
# '<app_name>[bot]'.
SYN_GITHUB_APP_NAME=syn-app

# GitHub App private key (fallback). Supports three formats: (1) file:<path> —
# read PEM from file; (2) raw PEM starting with '-----BEGIN'; (3)
# base64-encoded PEM string. Prefer SYN_GITHUB_APP_PRIVATE_KEY_FILE for Docker
# deployments.
SYN_GITHUB_PRIVATE_KEY=

# Path to PEM file containing the GitHub App private key. Takes priority over
# SYN_GITHUB_PRIVATE_KEY env var. In Docker: set to
# /run/secrets/github_app_private_key (mounted as tmpfs — never hits disk, not
# visible in docker inspect).
SYN_GITHUB_APP_PRIVATE_KEY_FILE=

# Webhook secret for validating GitHub webhook payloads. Set when configuring
# the GitHub App webhook URL. Used to verify webhook signatures (X-Hub-
# Signature-256).
SYN_GITHUB_WEBHOOK_SECRET=

# ============================================================================
# GITHUB EVENT POLLING (ADR-050)
# ============================================================================
# Hybrid webhook + polling ingestion. Polling is ON by default for zero-config
# onboarding — no webhook tunnel required. Set SYN_POLLING_DISABLED=true if
# using webhooks exclusively and you want zero API quota usage.

# Disable GitHub Events API polling entirely. Default: false (polling enabled).
SYN_POLLING_DISABLED=false

# Base polling interval in ACTIVE_POLLING mode (seconds). Used when no
# webhooks have been received recently. Minimum: 10.
SYN_POLLING_POLL_INTERVAL_SECONDS=60.0

# Polling interval in SAFETY_NET mode (seconds). Used when webhooks are
# healthy — infrequent catch-up polling only. Minimum: 60.
SYN_POLLING_SAFETY_NET_INTERVAL_SECONDS=300.0

# Seconds without a webhook delivery before the poller switches from
# SAFETY_NET to ACTIVE_POLLING mode. Minimum: 60.
SYN_POLLING_WEBHOOK_STALE_THRESHOLD_SECONDS=1800.0

# TTL for dedup keys in Redis (seconds). Events older than this can be
# re-processed if seen again. Default: 86400 (24 hours). Minimum: 3600.
SYN_POLLING_DEDUP_TTL_SECONDS=86400

# ============================================================================
# DEVELOPMENT TOOLING
# ============================================================================
# Dev-only tools (webhook proxies, debug servers). Not needed in production.

# Smee.io webhook proxy URL for local development. Forwards GitHub webhooks to
# your local machine. Create a channel at https://smee.io/new and paste the
# URL here. Used by 'just dev' to auto-start the webhook proxy.
DEV__SMEE_URL=

# ============================================================================
# WORKSPACE ISOLATION (ADR-021)
# ============================================================================
# All workspaces are isolated by default. These settings control HOW.

# Isolation backend to use.
SYN_WORKSPACE_ISOLATION_BACKEND=

# Number of pre-warmed workspace instances.
SYN_WORKSPACE_POOL_SIZE=100

# Maximum concurrent workspaces.
SYN_WORKSPACE_MAX_CONCURRENT=1000

# Enable cloud overflow when local capacity exceeded.
SYN_WORKSPACE_ENABLE_CLOUD_OVERFLOW=true

# Cloud provider for overflow: e2b or modal.
SYN_WORKSPACE_CLOUD_PROVIDER=e2b

# API key for cloud sandbox provider.
SYN_WORKSPACE_CLOUD_API_KEY=

# Cloud sandbox template/environment name.
SYN_WORKSPACE_CLOUD_TEMPLATE=syn-workspace

# Docker image for Claude agent execution.
SYN_WORKSPACE_DOCKER_IMAGE=agentic-workspace-claude-cli:latest

# Docker runtime to use (runsc = gVisor, runc = native).
SYN_WORKSPACE_DOCKER_RUNTIME=runsc

# Docker network for containers.
SYN_WORKSPACE_DOCKER_NETWORK=none

# ============================================================================
# WORKSPACE SECURITY POLICIES
# ============================================================================
# Defaults are maximally restrictive for compromised agent protection.

# Allow network access from workspaces. Default: False (full network
# isolation). Enable only if agents need to fetch dependencies or make API
# calls.
SYN_SECURITY_ALLOW_NETWORK=false

# Allowlisted hosts when network is enabled (comma-separated). Empty = allow
# all (not recommended). Example: 'pypi.org,api.github.com'
SYN_SECURITY_ALLOWED_HOSTS=

# Mount root filesystem as read-only. Workspace directory is always writable
# via tmpfs. Prevents agents from modifying system files.
SYN_SECURITY_READ_ONLY_ROOT=true

# Maximum size of workspace tmpfs. Format: Kubernetes resource format (1Gi,
# 512Mi, etc). Prevents agents from filling disk.
SYN_SECURITY_MAX_WORKSPACE_SIZE=1Gi

# Maximum memory per workspace. Format: Kubernetes resource format (512Mi,
# 1Gi, etc). Prevents single agent from exhausting host memory.
SYN_SECURITY_MAX_MEMORY=512Mi

# Maximum CPU cores per workspace. 0.5 = 50% of one core. Prevents single
# agent from monopolizing CPU.
SYN_SECURITY_MAX_CPU=0.5

# Maximum number of processes per workspace. Prevents fork bombs and process
# exhaustion.
SYN_SECURITY_MAX_PIDS=100

# Maximum execution time in seconds (hard limit). Default: 1 hour. Workspace
# is forcibly terminated after this.
SYN_SECURITY_MAX_EXECUTION_TIME=3600

# ============================================================================
# GIT IDENTITY FOR WORKSPACE COMMITS
# ============================================================================
# Git identity for agent commits. Prefer GitHub App for authentication.

# Git committer name (user.name).
SYN_GIT_USER_NAME=

# Git committer email (user.email).
SYN_GIT_USER_EMAIL=

# GitHub PAT for HTTPS authentication.
SYN_GIT_TOKEN=

# ============================================================================
# CONTAINER LOGGING (ADR-021)
# ============================================================================
# Controls logging inside isolated containers for observability.

# Minimum log level for container logs.
SYN_LOGGING_LEVEL=INFO

# Log format: 'json' for structured, 'text' for human-readable.
SYN_LOGGING_FORMAT=json

# Log shell commands executed in container.
SYN_LOGGING_LOG_COMMANDS=true

# Log tool calls made by agents.
SYN_LOGGING_LOG_TOOL_CALLS=true

# Log API calls (Claude, GitHub, etc). Disabled by default - can be verbose.
SYN_LOGGING_LOG_API_CALLS=false

# Redact sensitive data in logs (API keys, tokens, passwords).
SYN_LOGGING_REDACT_SECRETS=true

# Regex patterns for secret redaction.
SYN_LOGGING_REDACTION_PATTERNS=

# Log file path inside container.
SYN_LOGGING_LOG_FILE_PATH=/workspace/.logs/agent.jsonl

# Max log file size in MB before rotation.
SYN_LOGGING_MAX_LOG_SIZE_MB=10
