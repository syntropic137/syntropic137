# ============================================================================
# AGENTIC ENGINEERING FRAMEWORK - ENVIRONMENT CONFIGURATION
# ============================================================================
#
# This file is AUTO-GENERATED from the Settings classes.
# Do not edit manually - run: just gen-env
#
# Copy this file to .env and fill in your values.
# Required variables are marked with [REQUIRED].
# ============================================================================

# ============================================================================
# APPLICATION
# ============================================================================

# Application name for logging and identification
APP_NAME=agentic-engineering-framework

# Current environment: development, staging, production, test. Affects logging
# verbosity, error handling, and feature flags.
APP_ENVIRONMENT=development

# ============================================================================
# DATABASE
# ============================================================================

# Database connection pool size. Increase for high-traffic production.
DATABASE_POOL_SIZE=5

# Max overflow connections beyond pool_size for burst traffic.
DATABASE_POOL_OVERFLOW=10

# ============================================================================
# EVENT STORE
# ============================================================================

# Event Store Server gRPC host. For Docker: event-store (service name). For
# local dev: localhost
EVENT_STORE_HOST=localhost

# Event Store Server gRPC port.
EVENT_STORE_PORT=50051

# Tenant ID for multi-tenant Event Store Server. Each tenant has isolated
# event streams.
EVENT_STORE_TENANT_ID=aef

# Timeout for Event Store gRPC calls in seconds.
EVENT_STORE_TIMEOUT_SECONDS=30

# DEPRECATED: Use event_store_host and event_store_port instead. Legacy gRPC
# URL for the event store service.
EVENT_STORE_URL=

# ============================================================================
# LOGGING
# ============================================================================

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL. Use DEBUG for
# development, INFO for production.
LOG_LEVEL=INFO

# Log output format: 'json' for structured logs (production), 'console' for
# human-readable (development).
LOG_FORMAT=json

# ============================================================================
# AGENT CONFIGURATION
# ============================================================================

# Claude Code OAuth token for Claude models. Obtained via Claude Code OAuth
# flow. If set, takes priority over ANTHROPIC_API_KEY.
CLAUDE_CODE_OAUTH_TOKEN=

# Anthropic API key for Claude models. Get from:
# https://console.anthropic.com/settings/keys Required when using Claude agent
# adapter (unless CLAUDE_CODE_OAUTH_TOKEN is set).
ANTHROPIC_API_KEY=

# OpenAI API key for GPT models. Get from: https://platform.openai.com/api-
# keys Required when using OpenAI agent adapter.
OPENAI_API_KEY=

# Default timeout for agent operations in seconds.
DEFAULT_AGENT_TIMEOUT_SECONDS=300

# Default max tokens for agent responses.
DEFAULT_MAX_TOKENS=4096

# ============================================================================
# STORAGE
# ============================================================================

# Artifact storage backend: 'database' (PostgreSQL), 's3' (S3/Supabase). Start
# with database, migrate to s3 for large artifacts.
ARTIFACT_STORAGE_TYPE=database

# S3 bucket name for artifact storage. Required when artifact_storage_type is
# 's3'.
S3_BUCKET_NAME=

# S3-compatible endpoint URL. For Supabase:
# https://<project>.supabase.co/storage/v1/s3 Leave empty for AWS S3.
S3_ENDPOINT_URL=

# S3 access key ID. Required when using S3 storage.
S3_ACCESS_KEY_ID=

# S3 secret access key. Required when using S3 storage.
S3_SECRET_ACCESS_KEY=

# ============================================================================
# OTHER
# ============================================================================

# Enable debug mode. Shows detailed errors and enables debug logging. Never
# enable in production.
DEBUG=false

# Event Sourcing Platform database URL for domain events. Format:
# postgresql://user:password@host:port/database Used by Event Store (Rust) for
# event sourcing tables: events, aggregates, etc. For local dev:
# postgresql://aef:aef_dev_password@localhost:5432/aef For Docker:
# postgresql://aef:aef_dev_password@timescaledb:5432/aef
ESP_EVENT_STORE_DB_URL=

# AEF Observability database URL for agent metrics and application data.
# Format: postgresql://user:password@host:port/database Used by Dashboard API
# (Python) for: agent_events, workflows, artifacts, projections. For local
# dev: postgresql://aef:aef_dev_password@localhost:5432/aef For Docker:
# postgresql://aef:aef_dev_password@timescaledb:5432/aef NOTE: Points to SAME
# database as ESP after ADR-030 consolidation.
AEF_OBSERVABILITY_DB_URL=

# URL for the Collector service (Pattern 2: Event Log + CQRS). Format:
# http://host:port For local dev: http://localhost:8080 For Docker:
# http://collector:8080 When not set, tool events are not sent to collector.
COLLECTOR_URL=

# API key for Collector service authentication (optional).
COLLECTOR_API_KEY=

# URL for hook backend service for observability events. Format:
# http://host:port For local dev: http://localhost:8080 When not set, uses
# JSONL file backend at .agentic/hooks/events.jsonl
HOOK_BACKEND_URL=

# Number of events to batch before sending to hook backend.
HOOK_BATCH_SIZE=50

# Max seconds to wait before flushing buffered hook events.
HOOK_FLUSH_INTERVAL_SECONDS=1.0

# Port for the dashboard API server.
DASHBOARD_PORT=8000

# Host to bind the dashboard API server.
DASHBOARD_HOST=127.0.0.1

# ============================================================================
# GITHUB APP (Secure Authentication)
# ============================================================================
# GitHub App for secure API access. See docs/deployment/github-app-setup.md

# GitHub App ID. Get from: https://github.com/settings/apps/<app>/general
AEF_GITHUB_APP_ID=

# GitHub App name (slug). Used in commit attribution. Commits will show as
# '<app_name>[bot]'.
AEF_GITHUB_APP_NAME=aef-app

# GitHub App private key in PEM format. Generate from:
# https://github.com/settings/apps/<app>/privatekeys Store securely - never
# commit to git!
AEF_GITHUB_PRIVATE_KEY=

# GitHub App Installation ID. Get from:
# https://github.com/settings/installations or from webhook payload when app
# is installed.
AEF_GITHUB_INSTALLATION_ID=

# Webhook secret for validating GitHub webhook payloads. Set when configuring
# the GitHub App webhook URL. Used to verify webhook signatures (X-Hub-
# Signature-256).
AEF_GITHUB_WEBHOOK_SECRET=

# ============================================================================
# WORKSPACE ISOLATION (ADR-021)
# ============================================================================
# All workspaces are isolated by default. These settings control HOW.

# Isolation backend to use. Default: firecracker (Linux) or gvisor (macOS).
# Options: firecracker, kata, gvisor, docker_hardened, cloud
AEF_WORKSPACE_ISOLATION_BACKEND=

# Number of pre-warmed workspace instances. Higher = faster allocation, more
# memory usage. Set to 0 to disable pre-warming.
AEF_WORKSPACE_POOL_SIZE=100

# Maximum concurrent workspaces. Requests beyond this will queue or overflow
# to cloud.
AEF_WORKSPACE_MAX_CONCURRENT=1000

# Enable cloud overflow when local capacity exceeded. Requires cloud_api_key
# to be set.
AEF_WORKSPACE_ENABLE_CLOUD_OVERFLOW=true

# Cloud provider for overflow: e2b or modal.
AEF_WORKSPACE_CLOUD_PROVIDER=e2b

# API key for cloud sandbox provider. Required when enable_cloud_overflow is
# True. Get from: https://e2b.dev or https://modal.com
AEF_WORKSPACE_CLOUD_API_KEY=

# Cloud sandbox template/environment name.
AEF_WORKSPACE_CLOUD_TEMPLATE=aef-workspace

# Docker image for Claude agent execution. Includes Claude CLI with
# agentic_events hooks (ADR-029). Build with: just workspace-build
AEF_WORKSPACE_DOCKER_IMAGE=agentic-workspace-claude-cli:latest

# Docker runtime to use. runsc = gVisor (stronger isolation), runc = native
# (faster, weaker isolation)
AEF_WORKSPACE_DOCKER_RUNTIME=runsc

# Docker network for containers. Default: none (full network isolation). Use
# 'bridge' with allowed_hosts for controlled access.
AEF_WORKSPACE_DOCKER_NETWORK=none

# ============================================================================
# WORKSPACE SECURITY POLICIES
# ============================================================================
# Defaults are maximally restrictive for compromised agent protection.

# Allow network access from workspaces. Default: False (full network
# isolation). Enable only if agents need to fetch dependencies or make API
# calls.
AEF_SECURITY_ALLOW_NETWORK=false

# Allowlisted hosts when network is enabled (comma-separated). Empty = allow
# all (not recommended). Example: 'pypi.org,api.github.com'
AEF_SECURITY_ALLOWED_HOSTS=

# Mount root filesystem as read-only. Workspace directory is always writable
# via tmpfs. Prevents agents from modifying system files.
AEF_SECURITY_READ_ONLY_ROOT=true

# Maximum size of workspace tmpfs. Format: Kubernetes resource format (1Gi,
# 512Mi, etc). Prevents agents from filling disk.
AEF_SECURITY_MAX_WORKSPACE_SIZE=1Gi

# Maximum memory per workspace. Format: Kubernetes resource format (512Mi,
# 1Gi, etc). Prevents single agent from exhausting host memory.
AEF_SECURITY_MAX_MEMORY=512Mi

# Maximum CPU cores per workspace. 0.5 = 50% of one core. Prevents single
# agent from monopolizing CPU.
AEF_SECURITY_MAX_CPU=0.5

# Maximum number of processes per workspace. Prevents fork bombs and process
# exhaustion.
AEF_SECURITY_MAX_PIDS=100

# Maximum execution time in seconds (hard limit). Default: 1 hour. Workspace
# is forcibly terminated after this.
AEF_SECURITY_MAX_EXECUTION_TIME=3600

# ============================================================================
# GIT IDENTITY FOR WORKSPACE COMMITS
# ============================================================================
# Git identity for agent commits. Prefer GitHub App for authentication.

# Git committer name (user.name). Example: 'aef-bot[bot]' for automated
# commits. Required for commits - will fail if not configured.
AEF_GIT_USER_NAME=

# Git committer email (user.email). Example: 'bot@aef.dev' or GitHub noreply
# address. Required for commits - will fail if not configured.
AEF_GIT_USER_EMAIL=

# GitHub Personal Access Token for HTTPS authentication. Required scopes: repo
# (for private repos). Get from: https://github.com/settings/tokens Stored in
# ~/.git-credentials inside container. NOTE: For production, prefer GitHub App
# (AEF_GITHUB_*) over PAT.
AEF_GIT_TOKEN=

# ============================================================================
# CONTAINER LOGGING (ADR-021)
# ============================================================================
# Controls logging inside isolated containers for observability.

# Minimum log level for container logs. DEBUG for development, INFO for
# production.
AEF_LOGGING_LEVEL=INFO

# Log format: 'json' for structured logs (parsing), 'text' for human-readable
# (debugging).
AEF_LOGGING_FORMAT=json

# Log shell commands executed in container.
AEF_LOGGING_LOG_COMMANDS=true

# Log tool calls made by agents.
AEF_LOGGING_LOG_TOOL_CALLS=true

# Log API calls (Claude, GitHub, etc). Disabled by default - can be verbose.
AEF_LOGGING_LOG_API_CALLS=false

# Redact sensitive data in logs (API keys, tokens, passwords). ALWAYS enabled
# in production. Cannot be disabled in prod.
AEF_LOGGING_REDACT_SECRETS=true

# Regex patterns for secret redaction.
AEF_LOGGING_REDACTION_PATTERNS=

# Log file path inside container. Directory is created on workspace startup.
AEF_LOGGING_LOG_FILE_PATH=/workspace/.logs/agent.jsonl

# Max log file size in MB before rotation.
AEF_LOGGING_MAX_LOG_SIZE_MB=10
