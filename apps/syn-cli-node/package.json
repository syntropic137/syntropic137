{
  "name": "@syntropic137/cli",
  "version": "0.24.1",
  "description": "Syntropic137 CLI - Event-sourced workflow engine for AI agents",
  "type": "module",
  "bin": {
    "syn": "./dist/syn.js"
  },
  "main": "dist/syn.js",
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "generate:types": "tsx scripts/generate-types.ts",
    "check:api-drift": "tsx scripts/check-api-drift.ts",
    "check:untyped-api": "tsx scripts/check-untyped-api.ts",
    "generate:docs": "tsx scripts/generate-cli-docs.ts"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openapi-typescript": "^7.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "~5.9.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/syntropic137/syntropic137.git",
    "directory": "apps/syn-cli-node"
  },
  "license": "MIT"
}
