#!/usr/bin/env bash
set -euo pipefail

# =============================================================================
# syn-ctl — Standalone management script for Syntropic137 self-hosters
# =============================================================================
# Usage: ./syn-ctl <command> [options]
# Run './syn-ctl help' for available commands.
# =============================================================================

SYN_CTL_VERSION="0.1.0"
COMPOSE_FILE="docker-compose.syntropic137.yaml"
GITHUB_REPO="syntropic137/syntropic137"
GITHUB_API="https://api.github.com/repos/${GITHUB_REPO}"
SECRETS_DIR="./secrets"

# ---------------------------------------------------------------------------
# Color / formatting helpers
# ---------------------------------------------------------------------------
if [[ -t 1 ]] && command -v tput &>/dev/null && [[ "$(tput colors 2>/dev/null || echo 0)" -ge 8 ]]; then
    RED=$(tput setaf 1)
    GREEN=$(tput setaf 2)
    YELLOW=$(tput setaf 3)
    CYAN=$(tput setaf 6)
    BOLD=$(tput bold)
    RESET=$(tput sgr0)
else
    RED="" GREEN="" YELLOW="" CYAN="" BOLD="" RESET=""
fi

info()  { echo "${GREEN}[info]${RESET}  $*"; }
warn()  { echo "${YELLOW}[warn]${RESET}  $*" >&2; }
err()   { echo "${RED}[error]${RESET} $*" >&2; }
die()   { err "$@"; exit 1; }
header(){ echo "${BOLD}${CYAN}$*${RESET}"; }

# ---------------------------------------------------------------------------
# Prerequisite checks
# ---------------------------------------------------------------------------
require_cmd() {
    command -v "$1" &>/dev/null || die "'$1' is required but not found. Please install it and try again."
}

has_cmd() {
    command -v "$1" &>/dev/null
}

check_docker() {
    require_cmd docker
    docker info &>/dev/null || die "Docker is not running. Please start Docker and try again."
}

check_compose_file() {
    [[ -f "${WORK_DIR}/${COMPOSE_FILE}" ]] || \
        die "Compose file not found: ${WORK_DIR}/${COMPOSE_FILE}\nRun 'syn-ctl update' to download it, or check that you are in the correct directory."
}

check_jq() {
    if ! has_cmd jq; then
        warn "jq is not installed. Some commands may produce less readable output."
        warn "Install it: https://jqlang.github.io/jq/download/"
        return 1
    fi
    return 0
}

# ---------------------------------------------------------------------------
# Working directory — auto-detect where syn-ctl lives
# ---------------------------------------------------------------------------
resolve_work_dir() {
    local script_dir
    script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    WORK_DIR="${script_dir}"
}

# ---------------------------------------------------------------------------
# Environment helpers
# ---------------------------------------------------------------------------
load_env() {
    if [[ -f "${WORK_DIR}/.env" ]]; then
        # shellcheck disable=SC1091
        set -a
        source "${WORK_DIR}/.env"
        set +a
    fi
}

get_current_version() {
    if [[ -n "${SYN_VERSION:-}" ]]; then
        echo "${SYN_VERSION}"
    else
        echo "${SYN_CTL_VERSION}"
    fi
}

# Compose wrapper — always targets the correct file and project directory
dc() {
    docker compose -f "${WORK_DIR}/${COMPOSE_FILE}" --project-directory "${WORK_DIR}" "$@"
}

# ---------------------------------------------------------------------------
# Env file manipulation
# ---------------------------------------------------------------------------
env_set() {
    # env_set KEY VALUE — upsert a key in .env
    local key="$1" value="$2" envfile="${WORK_DIR}/.env"
    if [[ ! -f "${envfile}" ]]; then
        echo "${key}=${value}" > "${envfile}"
        return
    fi
    if grep -q "^${key}=" "${envfile}" 2>/dev/null; then
        # Use a temp file for portability (BSD + GNU sed differ on -i)
        local tmp="${envfile}.tmp.$$"
        sed "s|^${key}=.*|${key}=${value}|" "${envfile}" > "${tmp}" && mv "${tmp}" "${envfile}"
    else
        echo "${key}=${value}" >> "${envfile}"
    fi
}

# ---------------------------------------------------------------------------
# Prompt helpers
# ---------------------------------------------------------------------------
prompt() {
    local var="$1" msg="$2" default="${3:-}"
    local input
    if [[ -n "${default}" ]]; then
        read -rp "${msg} [${default}]: " input
        eval "${var}=\"${input:-${default}}\""
    else
        read -rp "${msg}: " input
        eval "${var}=\"${input}\""
    fi
}

confirm() {
    local msg="${1:-Continue?}"
    local reply
    read -rp "${msg} [y/N] " reply
    [[ "${reply}" =~ ^[Yy]$ ]]
}

# ---------------------------------------------------------------------------
# GitHub API helpers
# ---------------------------------------------------------------------------
gh_api() {
    local endpoint="$1"
    local url="${GITHUB_API}${endpoint}"
    local headers=()
    [[ -n "${GITHUB_TOKEN:-}" ]] && headers+=(-H "Authorization: token ${GITHUB_TOKEN}")
    curl -fsSL "${headers[@]}" "${url}" 2>/dev/null
}

get_latest_release() {
    gh_api "/releases/latest"
}

get_release_by_tag() {
    gh_api "/releases/tags/$1"
}

# ---------------------------------------------------------------------------
# 6a: Core commands
# ---------------------------------------------------------------------------
cmd_up() {
    check_docker
    check_compose_file
    info "Starting Syntropic137 services..."
    dc up -d
    info "Services started. Run 'syn-ctl status' to check health."
}

cmd_down() {
    check_docker
    check_compose_file
    info "Stopping Syntropic137 services..."
    dc down
    info "All services stopped."
}

cmd_status() {
    check_docker
    check_compose_file
    header "Syntropic137 Service Status"
    echo ""
    dc ps
    echo ""

    # Health summary
    local total running healthy unhealthy
    total=$(docker ps -a --filter "label=com.docker.compose.project" --format '{{.Names}}' | grep -c "syn137" || true)
    running=$(docker ps --filter "label=com.docker.compose.project" --format '{{.Names}}' | grep -c "syn137" || true)
    healthy=$(docker ps --filter "health=healthy" --format '{{.Names}}' | grep -c "syn137" || true)
    unhealthy=$(docker ps --filter "health=unhealthy" --format '{{.Names}}' | grep -c "syn137" || true)

    header "Health Summary"
    echo "  Total containers:   ${total}"
    echo "  Running:            ${running}"
    echo "  Healthy:            ${GREEN}${healthy}${RESET}"
    if [[ "${unhealthy}" -gt 0 ]]; then
        echo "  Unhealthy:          ${RED}${unhealthy}${RESET}"
    fi
}

cmd_logs() {
    check_docker
    check_compose_file
    dc logs -f "$@"
}

cmd_version() {
    header "syn-ctl version"
    echo "  syn-ctl:   ${SYN_CTL_VERSION}"
    echo "  SYN_VERSION (from .env): ${SYN_VERSION:-not set}"

    # Try to get running API version
    if check_docker 2>/dev/null && [[ -f "${WORK_DIR}/${COMPOSE_FILE}" ]]; then
        local api_version
        api_version=$(docker exec syn137-api sh -c 'echo ${SYN_VERSION:-unknown}' 2>/dev/null || echo "not running")
        echo "  API (running):     ${api_version}"
    fi
}

# ---------------------------------------------------------------------------
# 6b: Update command
# ---------------------------------------------------------------------------
cmd_update() {
    check_docker
    require_cmd curl

    info "Checking for updates..."

    local release_json
    release_json=$(get_latest_release) || die "Failed to query GitHub API. Check your internet connection."

    local latest_tag
    if check_jq; then
        latest_tag=$(echo "${release_json}" | jq -r '.tag_name')
    else
        latest_tag=$(echo "${release_json}" | grep -o '"tag_name"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"tag_name"[[:space:]]*:[[:space:]]*"//;s/"//')
    fi

    [[ -z "${latest_tag}" || "${latest_tag}" == "null" ]] && die "Could not determine latest release."

    local current
    current=$(get_current_version)
    info "Current version: ${current}"
    info "Latest release:  ${latest_tag}"

    if [[ "${current}" == "${latest_tag}" ]]; then
        info "Already up to date."
        return 0
    fi

    if ! confirm "Update to ${latest_tag}?"; then
        info "Update cancelled."
        return 0
    fi

    download_release_assets "${latest_tag}"
    self_update_if_needed "${latest_tag}"

    info "Pulling updated images..."
    dc pull

    info "Restarting services..."
    dc up -d

    env_set "SYN_VERSION" "${latest_tag}"
    info "Update complete. Now running ${latest_tag}."
}

download_release_assets() {
    local tag="$1"
    local base_url="https://github.com/${GITHUB_REPO}/releases/download/${tag}"
    local tmpdir="${WORK_DIR}/.syn-ctl-update.$$"
    mkdir -p "${tmpdir}"
    trap 'rm -rf "${tmpdir}"' RETURN

    info "Downloading release assets for ${tag}..."

    # Download assets
    curl -fsSL -o "${tmpdir}/${COMPOSE_FILE}" "${base_url}/${COMPOSE_FILE}" \
        || die "Failed to download ${COMPOSE_FILE}"
    curl -fsSL -o "${tmpdir}/.env.example" "${base_url}/.env.example" 2>/dev/null || true
    curl -fsSL -o "${tmpdir}/syn-ctl" "${base_url}/syn-ctl" 2>/dev/null || true
    curl -fsSL -o "${tmpdir}/SHA256SUMS" "${base_url}/SHA256SUMS" 2>/dev/null || true

    # Verify checksums if available
    if [[ -f "${tmpdir}/SHA256SUMS" ]]; then
        info "Verifying checksums..."
        (cd "${tmpdir}" && sha256sum --check SHA256SUMS 2>/dev/null || shasum -a 256 --check SHA256SUMS 2>/dev/null) \
            || die "Checksum verification failed! Aborting update."
        info "Checksums verified."
    else
        warn "SHA256SUMS not found in release. Skipping checksum verification."
    fi

    # Install compose file
    cp "${tmpdir}/${COMPOSE_FILE}" "${WORK_DIR}/${COMPOSE_FILE}"
    info "Updated ${COMPOSE_FILE}"

    # Install .env.example (don't overwrite .env)
    if [[ -f "${tmpdir}/.env.example" ]]; then
        cp "${tmpdir}/.env.example" "${WORK_DIR}/.env.example"
        info "Updated .env.example (your .env was not modified)"
    fi
}

# ---------------------------------------------------------------------------
# 6f: Self-update
# ---------------------------------------------------------------------------
self_update_if_needed() {
    local tag="$1"
    local base_url="https://github.com/${GITHUB_REPO}/releases/download/${tag}"
    local tmpfile="${WORK_DIR}/syn-ctl.new.$$"

    info "Checking for syn-ctl update..."
    if ! curl -fsSL -o "${tmpfile}" "${base_url}/syn-ctl" 2>/dev/null; then
        warn "No syn-ctl in release assets. Skipping self-update."
        rm -f "${tmpfile}"
        return 0
    fi

    # Verify checksum
    local sums_file="${WORK_DIR}/.syn-ctl-sums.$$"
    if curl -fsSL -o "${sums_file}" "${base_url}/SHA256SUMS" 2>/dev/null; then
        local expected_hash actual_hash
        expected_hash=$(grep "syn-ctl" "${sums_file}" | grep -v "\.new" | head -1 | awk '{print $1}')
        if [[ -n "${expected_hash}" ]]; then
            actual_hash=$(shasum -a 256 "${tmpfile}" 2>/dev/null | awk '{print $1}' \
                          || sha256sum "${tmpfile}" 2>/dev/null | awk '{print $1}')
            if [[ "${expected_hash}" != "${actual_hash}" ]]; then
                rm -f "${tmpfile}" "${sums_file}"
                die "syn-ctl checksum mismatch! Expected ${expected_hash}, got ${actual_hash}."
            fi
            info "syn-ctl checksum verified."
        fi
        rm -f "${sums_file}"
    fi

    # Replace self
    chmod +x "${tmpfile}"
    mv "${tmpfile}" "${WORK_DIR}/syn-ctl"
    info "syn-ctl updated to ${tag}."
}

# ---------------------------------------------------------------------------
# 6c: Rollback command
# ---------------------------------------------------------------------------
cmd_rollback() {
    local version="${1:-}"
    [[ -z "${version}" ]] && die "Usage: syn-ctl rollback <version>\nExample: syn-ctl rollback v0.16.1"

    check_docker
    require_cmd curl

    info "Rolling back to ${version}..."

    # Verify the release exists
    local release_json
    release_json=$(get_release_by_tag "${version}") || die "Release ${version} not found."

    if ! confirm "Roll back to ${version}? This will restart all services."; then
        info "Rollback cancelled."
        return 0
    fi

    download_release_assets "${version}"

    info "Pulling images for ${version}..."
    dc pull

    info "Restarting services..."
    dc up -d

    env_set "SYN_VERSION" "${version}"
    info "Rollback complete. Now running ${version}."
}

# ---------------------------------------------------------------------------
# 6d: Add-feature commands
# ---------------------------------------------------------------------------
cmd_add_github_app() {
    local manual=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --manual) manual=true; shift ;;
            *) die "Unknown option: $1. Usage: syn-ctl add-github-app [--manual]" ;;
        esac
    done

    header "GitHub App Setup"
    echo ""

    # Check current state
    load_env
    if [[ -n "${SYN_GITHUB_APP_ID:-}" ]]; then
        warn "GitHub App already configured (App ID: ${SYN_GITHUB_APP_ID})."
        if ! confirm "Reconfigure?"; then
            return 0
        fi
    fi

    if [[ "${manual}" == true ]]; then
        _add_github_app_manual
    else
        _add_github_app_browser
    fi

    info "Restarting API to apply changes..."
    check_docker
    check_compose_file
    dc restart api
    info "GitHub App configured successfully."
}

_add_github_app_browser() {
    local gateway_port="${SYN_GATEWAY_PORT:-8137}"
    local manifest_url="http://localhost:${gateway_port}/api/v1/github/app/manifest"

    echo "This will open the GitHub App creation flow in your browser."
    echo ""
    echo "  1. A browser window will open with the GitHub App manifest flow."
    echo "  2. Click 'Create GitHub App' on the GitHub page."
    echo "  3. GitHub will redirect back with your new app credentials."
    echo ""

    if has_cmd open; then
        open "${manifest_url}" 2>/dev/null || true
    elif has_cmd xdg-open; then
        xdg-open "${manifest_url}" 2>/dev/null || true
    else
        echo "Open this URL in your browser:"
        echo "  ${manifest_url}"
    fi

    echo ""
    echo "After completing the flow, paste the callback URL here."
    local callback_url
    prompt callback_url "Callback URL"

    # Extract parameters from callback URL (the API handles this, but we confirm)
    info "GitHub App created via manifest flow."
    info "The API has stored the credentials automatically."
    info "If you need to verify, check your .env for SYN_GITHUB_APP_ID."
}

_add_github_app_manual() {
    echo "Enter your GitHub App credentials:"
    echo ""

    local app_id app_name webhook_secret pem_path

    prompt app_id "App ID"
    [[ -z "${app_id}" ]] && die "App ID is required."

    prompt app_name "App Name (slug)"
    [[ -z "${app_name}" ]] && die "App Name is required."

    prompt webhook_secret "Webhook Secret"
    [[ -z "${webhook_secret}" ]] && die "Webhook Secret is required."

    prompt pem_path "Path to private key PEM file"
    [[ ! -f "${pem_path}" ]] && die "PEM file not found: ${pem_path}"

    # Read PEM and convert to single-line for .env storage
    local pem_content
    pem_content=$(cat "${pem_path}")

    env_set "SYN_GITHUB_APP_ID" "${app_id}"
    env_set "SYN_GITHUB_APP_NAME" "${app_name}"
    env_set "SYN_GITHUB_WEBHOOK_SECRET" "${webhook_secret}"
    # Store PEM as base64 to avoid multiline .env issues
    local pem_b64
    pem_b64=$(echo "${pem_content}" | base64 | tr -d '\n')
    env_set "SYN_GITHUB_PRIVATE_KEY" "${pem_b64}"

    info "Credentials written to .env"
    info "  SYN_GITHUB_APP_ID=${app_id}"
    info "  SYN_GITHUB_APP_NAME=${app_name}"
    info "  SYN_GITHUB_WEBHOOK_SECRET=****"
    info "  SYN_GITHUB_PRIVATE_KEY=(base64-encoded PEM)"
}

cmd_add_cloudflare() {
    header "Cloudflare Tunnel Setup"
    echo ""

    load_env
    if [[ -n "${CLOUDFLARE_TUNNEL_TOKEN:-}" ]]; then
        warn "Cloudflare tunnel already configured."
        if ! confirm "Reconfigure?"; then
            return 0
        fi
    fi

    echo "Set up a Cloudflare Tunnel to expose Syntropic137 to the internet."
    echo ""
    echo "  1. Open the Cloudflare dashboard and create a tunnel."
    echo "  2. Copy the tunnel token and hostname."
    echo ""

    local dashboard_url="https://dash.cloudflare.com/?to=/:account/tunnels"
    if has_cmd open; then
        open "${dashboard_url}" 2>/dev/null || true
    elif has_cmd xdg-open; then
        xdg-open "${dashboard_url}" 2>/dev/null || true
    else
        echo "Open this URL in your browser:"
        echo "  ${dashboard_url}"
    fi

    echo ""
    local tunnel_token tunnel_hostname

    prompt tunnel_token "Tunnel Token"
    [[ -z "${tunnel_token}" ]] && die "Tunnel token is required."

    prompt tunnel_hostname "Tunnel Hostname (e.g., syn.example.com)"
    [[ -z "${tunnel_hostname}" ]] && die "Tunnel hostname is required."

    env_set "CLOUDFLARE_TUNNEL_TOKEN" "${tunnel_token}"
    env_set "CLOUDFLARE_TUNNEL_HOSTNAME" "${tunnel_hostname}"

    info "Cloudflare configuration written to .env"
    info "  CLOUDFLARE_TUNNEL_HOSTNAME=${tunnel_hostname}"

    check_docker
    check_compose_file
    info "Restarting services to apply tunnel configuration..."
    dc up -d
    info "Cloudflare tunnel configured. Your instance should be available at https://${tunnel_hostname} shortly."
}

cmd_add_1password() {
    header "1Password Integration Setup"
    echo ""

    require_cmd op

    # Check 1Password CLI auth
    if ! op whoami &>/dev/null; then
        die "Not signed in to 1Password CLI. Run 'op signin' first."
    fi

    local op_user
    op_user=$(op whoami --format=json 2>/dev/null | (check_jq && jq -r '.email' || grep -o '"email":"[^"]*"' | sed 's/.*"email":"//;s/"//'))
    info "Signed in as: ${op_user}"

    load_env

    local vault_name="Syntropic137"
    echo ""
    echo "This will create a 1Password vault '${vault_name}' (if it doesn't exist)"
    echo "and push your current secrets there for backup and team sharing."
    echo ""

    if ! confirm "Continue?"; then
        return 0
    fi

    # Create vault if needed
    if ! op vault get "${vault_name}" &>/dev/null; then
        info "Creating vault '${vault_name}'..."
        op vault create "${vault_name}" --description "Syntropic137 self-host secrets" || die "Failed to create vault."
    else
        info "Vault '${vault_name}' already exists."
    fi

    # Store service account token reference
    local sa_token
    prompt sa_token "1Password Service Account Token (for container access)"
    if [[ -n "${sa_token}" ]]; then
        env_set "OP_SERVICE_ACCOUNT_TOKEN" "${sa_token}"
        info "Service account token written to .env"
    fi

    info "1Password integration configured."
    info "Use 'syn-ctl secrets-push' to push secrets to the vault."
}

# ---------------------------------------------------------------------------
# 6e: Secrets commands
# ---------------------------------------------------------------------------
cmd_secrets_push() {
    header "Push Secrets to 1Password"
    require_cmd op

    if ! op whoami &>/dev/null; then
        die "Not signed in to 1Password CLI. Run 'op signin' first."
    fi

    load_env
    local vault_name="Syntropic137"

    if ! op vault get "${vault_name}" &>/dev/null; then
        die "Vault '${vault_name}' not found. Run 'syn-ctl add-1password' first."
    fi

    info "Pushing secrets to 1Password vault '${vault_name}'..."

    # Push .env as a secure note
    if [[ -f "${WORK_DIR}/.env" ]]; then
        op item create \
            --vault "${vault_name}" \
            --category "Secure Note" \
            --title "syntropic137-env" \
            "notesPlain=$(cat "${WORK_DIR}/.env")" \
            --tags "syntropic137,env" 2>/dev/null \
        || op item edit "syntropic137-env" \
            --vault "${vault_name}" \
            "notesPlain=$(cat "${WORK_DIR}/.env")" 2>/dev/null \
        || warn "Failed to push .env to 1Password."
        info "Pushed .env"
    fi

    # Push secret files
    local secrets_dir="${WORK_DIR}/secrets"
    if [[ -d "${secrets_dir}" ]]; then
        for secret_file in "${secrets_dir}"/*.secret; do
            [[ -f "${secret_file}" ]] || continue
            local name
            name=$(basename "${secret_file}" .secret)
            op item create \
                --vault "${vault_name}" \
                --category "Password" \
                --title "syntropic137-${name}" \
                "password=$(cat "${secret_file}")" \
                --tags "syntropic137,secret" 2>/dev/null \
            || op item edit "syntropic137-${name}" \
                --vault "${vault_name}" \
                "password=$(cat "${secret_file}")" 2>/dev/null \
            || warn "Failed to push ${name}"
            info "Pushed ${name}"
        done
    fi

    info "Secrets push complete."
}

cmd_secrets_pull() {
    header "Pull Secrets from 1Password"
    require_cmd op

    if ! op whoami &>/dev/null; then
        die "Not signed in to 1Password CLI. Run 'op signin' first."
    fi

    local vault_name="Syntropic137"

    if ! op vault get "${vault_name}" &>/dev/null; then
        die "Vault '${vault_name}' not found. Run 'syn-ctl add-1password' first."
    fi

    info "Pulling secrets from 1Password vault '${vault_name}'..."

    # Pull .env
    local env_content
    env_content=$(op item get "syntropic137-env" --vault "${vault_name}" --fields notesPlain 2>/dev/null || true)
    if [[ -n "${env_content}" ]]; then
        if [[ -f "${WORK_DIR}/.env" ]]; then
            cp "${WORK_DIR}/.env" "${WORK_DIR}/.env.backup.$(date +%s)"
            info "Backed up current .env"
        fi
        echo "${env_content}" > "${WORK_DIR}/.env"
        info "Pulled .env"
    else
        warn "No .env found in 1Password."
    fi

    # Pull secret files
    mkdir -p "${WORK_DIR}/secrets"
    local items
    items=$(op item list --vault "${vault_name}" --tags "syntropic137,secret" --format json 2>/dev/null || echo "[]")
    if check_jq; then
        echo "${items}" | jq -r '.[].title' | while read -r title; do
            local name="${title#syntropic137-}"
            local value
            value=$(op item get "${title}" --vault "${vault_name}" --fields password 2>/dev/null || true)
            if [[ -n "${value}" ]]; then
                echo "${value}" > "${WORK_DIR}/secrets/${name}.secret"
                chmod 600 "${WORK_DIR}/secrets/${name}.secret"
                info "Pulled ${name}"
            fi
        done
    else
        warn "jq is required to pull individual secrets. Install jq and try again."
    fi

    info "Secrets pull complete."
}

cmd_secrets_seal() {
    header "Seal Secrets (AES-256 Encryption)"
    require_cmd openssl

    local secrets_archive="${WORK_DIR}/secrets-sealed.enc"

    # Collect files to seal
    local files_to_seal=()
    [[ -f "${WORK_DIR}/.env" ]] && files_to_seal+=(".env")
    if [[ -d "${WORK_DIR}/secrets" ]]; then
        for f in "${WORK_DIR}/secrets"/*.secret; do
            [[ -f "${f}" ]] && files_to_seal+=("secrets/$(basename "${f}")")
        done
    fi

    if [[ ${#files_to_seal[@]} -eq 0 ]]; then
        die "No secrets found to seal. Expected .env or files in ./secrets/"
    fi

    info "Files to seal:"
    for f in "${files_to_seal[@]}"; do
        echo "  - ${f}"
    done
    echo ""

    # Read passphrase
    local passphrase passphrase_confirm
    read -rsp "Enter passphrase: " passphrase
    echo ""
    read -rsp "Confirm passphrase: " passphrase_confirm
    echo ""

    [[ "${passphrase}" != "${passphrase_confirm}" ]] && die "Passphrases do not match."
    [[ -z "${passphrase}" ]] && die "Passphrase cannot be empty."

    # Create tar archive and encrypt
    info "Sealing secrets..."
    tar -czf - -C "${WORK_DIR}" "${files_to_seal[@]}" \
        | openssl enc -aes-256-cbc -salt -pbkdf2 -iter 100000 -pass "pass:${passphrase}" \
        -out "${secrets_archive}"

    chmod 600 "${secrets_archive}"
    info "Secrets sealed to: ${secrets_archive}"
    info "Store this file safely. You will need the passphrase to unseal."
}

cmd_secrets_unseal() {
    header "Unseal Secrets (AES-256 Decryption)"
    require_cmd openssl

    local secrets_archive="${WORK_DIR}/secrets-sealed.enc"

    [[ -f "${secrets_archive}" ]] || die "Sealed secrets file not found: ${secrets_archive}"

    local passphrase
    read -rsp "Enter passphrase: " passphrase
    echo ""
    [[ -z "${passphrase}" ]] && die "Passphrase cannot be empty."

    info "Unsealing secrets..."
    openssl enc -aes-256-cbc -d -salt -pbkdf2 -iter 100000 -pass "pass:${passphrase}" \
        -in "${secrets_archive}" \
        | tar -xzf - -C "${WORK_DIR}" \
        || die "Failed to unseal. Wrong passphrase?"

    # Restrict permissions on unsealed files
    [[ -f "${WORK_DIR}/.env" ]] && chmod 600 "${WORK_DIR}/.env"
    if [[ -d "${WORK_DIR}/secrets" ]]; then
        chmod 700 "${WORK_DIR}/secrets"
        chmod 600 "${WORK_DIR}/secrets"/*.secret 2>/dev/null || true
    fi

    info "Secrets unsealed successfully."
}

# ---------------------------------------------------------------------------
# Help
# ---------------------------------------------------------------------------
cmd_help() {
    cat <<HELP
${BOLD}syn-ctl${RESET} v${SYN_CTL_VERSION} — Syntropic137 management tool

${BOLD}USAGE${RESET}
    syn-ctl <command> [options]

${BOLD}CORE COMMANDS${RESET}
    up                      Start all services
    down                    Stop all services
    status                  Show service status and health
    logs [service]          Tail service logs (optionally filter by service)
    version                 Show syn-ctl and running API version

${BOLD}LIFECYCLE${RESET}
    update                  Check for updates and apply the latest release
    rollback <version>      Roll back to a specific release version

${BOLD}ADD-ON SETUP${RESET}
    add-github-app          Guided GitHub App setup (opens browser)
    add-github-app --manual Paste credentials manually (headless VPS)
    add-cloudflare          Guided Cloudflare Tunnel setup
    add-1password           Guided 1Password backup integration

${BOLD}SECRETS MANAGEMENT${RESET}
    secrets-push            Push local secrets to 1Password
    secrets-pull            Pull secrets from 1Password to local files
    secrets-seal            Encrypt secrets with a passphrase (AES-256)
    secrets-unseal          Decrypt sealed secrets

${BOLD}OPTIONS${RESET}
    help, --help, -h        Show this help message

${BOLD}ENVIRONMENT${RESET}
    GITHUB_TOKEN            GitHub API token (optional, avoids rate limits)
    SYN_VERSION             Current deployed version (read from .env)

${BOLD}EXAMPLES${RESET}
    syn-ctl up                          # Start services
    syn-ctl logs api                    # Follow API logs
    syn-ctl update                      # Update to latest release
    syn-ctl rollback v0.16.0            # Roll back to v0.16.0
    syn-ctl add-github-app --manual     # Configure GitHub App on headless VPS
    syn-ctl secrets-seal                # Encrypt secrets for backup
HELP
}

# ---------------------------------------------------------------------------
# Main entry point
# ---------------------------------------------------------------------------
main() {
    resolve_work_dir
    load_env

    case "${1:-}" in
        up)                 cmd_up ;;
        down)               cmd_down ;;
        status)             cmd_status ;;
        logs)               shift; cmd_logs "$@" ;;
        version)            cmd_version ;;
        update)             cmd_update ;;
        rollback)           shift; cmd_rollback "$@" ;;
        add-github-app)     shift; cmd_add_github_app "$@" ;;
        add-cloudflare)     cmd_add_cloudflare ;;
        add-1password)      cmd_add_1password ;;
        secrets-push)       cmd_secrets_push ;;
        secrets-pull)       cmd_secrets_pull ;;
        secrets-seal)       cmd_secrets_seal ;;
        secrets-unseal)     cmd_secrets_unseal ;;
        help|--help|-h)     cmd_help ;;
        "")                 cmd_help ;;
        *)                  err "Unknown command: $1"; echo ""; cmd_help; exit 1 ;;
    esac
}

main "$@"
